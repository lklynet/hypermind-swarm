# This .env.example file provides you a list of all available env variables and their default values.
# You can copy this and modify anything you need, however we strongly suggest leaving most of these untouched
# as we continue improving the system to be as performant as possible. That said... hey... if you have resources to waste
# and know what you're doing just go for it. 

TOPIC_NAME=hypermind-swarm-v1
# WARNING: enabling this derives private identity keys from the device MAC address.
# MAC addresses have limited entropy and may be observable, so this identity can be cloned.
# Pings are public and signed; they are not end-to-end encrypted.
# leaving this disabled (as default) will assign you a different username each time you restart the service.
DEVICE_PERSISTENCE=false
STORAGE_PATH=./storage

# Mega-node mode: persists all network traffic, serves as catch-up relay for the swarm.
# When enabled, this node never evicts messages from its store and advertises itself
# as a catch-up source so other nodes can request missed messages.
MEGA_NODE=false
MEGA_CATCHUP_BATCH_SIZE=50
MEGA_MAX_CATCHUP_MESSAGES=5000
MAX_CATCHUP_MESSAGE_SIZE=65536

# you can increase this but you will lose connection to peers that use the default one.
# more zeroes mean more security but also more time to generate a valid pow
# cpu going brr brr brr
POW_PREFIX=00000
VERIFICATION_POW_PREFIX=00000

MAX_PEERS=100000
MAX_MESSAGE_SIZE=2048
MAX_RELAY_HOPS=10
MAX_CONNECTIONS=50
MAX_TRACKED_CORES=256

MAX_SOCKET_BUFFER_SIZE=131072
MAX_MESSAGES_PER_SECOND=10
MAX_SSE_CLIENTS=1000
MAX_SSE_CLIENTS_PER_IP=5

MAX_CONTENT_LENGTH=2000
MAX_USERNAME_LENGTH=50

HEARTBEAT_INTERVAL=30000
CONNECTION_ROTATION_INTERVAL=300000
PEER_TIMEOUT=45000
SSE_HEARTBEAT_INTERVAL=15000

PING_RATE_LIMIT=5
COMMENT_RATE_LIMIT=10
RATE_LIMIT_WINDOW_MS=10000

DEFAULT_MESSAGE_TTL=10
RELAY_PEER_COUNT=10

LRU_CACHE_CAPACITY=2000

PORT=3000
HOST=127.0.0.1
CHAT_RATE_LIMIT=5000
VISUAL_LIMIT=500

# Dashboard auth. Required with a non-loopback HOST; password minimum is 12 characters.
# For remote access, also configure WEB_ALLOWED_HOSTS and terminate HTTPS at a trusted proxy.
WEB_AUTH=
WEB_ALLOWED_HOSTS=localhost:3000,127.0.0.1:3000
TRUST_PROXY=false
WEB_AUTH_SESSION_TTL_MS=43200000
WEB_AUTH_MAX_SESSIONS=128

# You need an api key, free tier gives you 100 gifs per hour, not that many but I doubt anyone would
# need more than them, you can always enter gifs url manually. 
GIPHY_API_KEY=dc6zaTOxFJmzC
