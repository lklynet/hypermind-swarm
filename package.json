{
  "name": "hypermind-swarm",
  "version": "1.6.0",
  "description": "A decentralized P2P Twitter-like swarm",
  "main": "electron-main.js",
  "scripts": {
    "build:css": "sass src/styles/style.scss public/style.css --style=compressed --no-source-map",
    "watch:css": "sass src/styles/style.scss public/style.css --watch --style=compressed --no-source-map",
    "start": "npm run build:css && node server.js",
    "dev": "npm run watch:css & node server.js",
    "second-instance": "STORAGE_PATH=./storage2 PORT=3002 npm run dev",
    "verify": "npm run build:css && node --check server.js && node --check electron-main.js && node --check src/web/routes.js && node --check src/p2p/swarm.js && node --check src/p2p/validation/message-security.js && node --check src/p2p/validation/message-validator.js && npm test",
    "electron": "electron .",
    "build:electron": "npm run build:css && electron-builder",
    "dist:mac": "npm run build:css && electron-builder --mac",
    "dist:win": "npm run build:css && electron-builder --win",
    "dist:linux": "npm run build:css && electron-builder --linux",
    "test": "node --test --test-concurrency=1 test/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lklynet/hypermind.git"
  },
  "keywords": [
    "p2p",
    "decentralized",
    "counter",
    "hyperswarm",
    "docker"
  ],
  "author": "lklynet",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lklynet/hypermind/issues"
  },
  "homepage": "https://github.com/lklynet/hypermind#readme",
  "type": "commonjs",
  "dependencies": {
    "@dicebear/collection": "^9.2.4",
    "@dicebear/core": "^9.2.4",
    "@fortawesome/fontawesome-free": "^7.3.1",
    "b4a": "^1.7.3",
    "corestore": "^7.7.0",
    "dompurify": "^3.4.12",
    "express": "^5.2.1",
    "hyperswarm": "^4.16.0",
    "sodium-native": "^5.0.10"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "sass": "^1.97.2"
  },
  "build": {
    "appId": "com.lklynet.hypermind",
    "productName": "Hypermind",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron-main.js",
      "electron-main-preload.js",
      "electron-preload.js",
      "electron-preferences.html",
      "server.js",
      "public/**/*",
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.social-networking",
      "icon": "build/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Network"
    },
    "publish": {
      "provider": "github",
      "owner": "lklynet",
      "repo": "hypermind-swarm",
      "releaseType": "release"
    }
  }
}
