{
  "name": "hypermind-swarm",
  "version": "1.2.1",
  "description": "A decentralized P2P Twitter-like swarm",
  "main": "server.js",
  "scripts": {
    "build:css": "sass src/styles/style.scss public/style.css --style=compressed --no-source-map",
    "watch:css": "sass src/styles/style.scss public/style.css --watch --style=compressed --no-source-map",
    "start": "npm run build:css && node server.js",
    "dev": "npm run watch:css & node server.js",
    "second-instance": "STORAGE_PATH=./storage2 PORT=3002 npm run dev",
    "verify": "npm run build:css && node --check server.js && node --check src/web/routes.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lklynet/hypermind.git"
  },
  "keywords": [
    "p2p",
    "decentralized",
    "counter",
    "hyperswarm",
    "docker"
  ],
  "author": "lklynet",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lklynet/hypermind/issues"
  },
  "homepage": "https://github.com/lklynet/hypermind#readme",
  "type": "commonjs",
  "dependencies": {
    "@dicebear/collection": "^9.2.4",
    "@dicebear/core": "^9.2.4",
    "b4a": "^1.7.3",
    "corestore": "^7.7.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "hyperswarm": "^4.16.0",
    "sodium-native": "^5.0.10"
  },
  "devDependencies": {
    "sass": "^1.97.2"
  }
}
